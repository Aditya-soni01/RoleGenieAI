.env.example

# Database Configuration
DATABASE_URL=sqlite:///./ai_job_assistant.db

# JWT Configuration
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# API Configuration
API_TITLE=AI Job Assistant API
API_VERSION=1.0.0
DEBUG=True

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# AI Provider Configuration
# Supported providers today: openai, anthropic, openrouter
AI_PROVIDER=openai
AI_MODEL=gpt-5.2

# OpenAI API Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional Anthropic Claude Configuration
# Set AI_PROVIDER=anthropic and AI_MODEL=claude-sonnet-4-6 to use this.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# Optional OpenRouter Configuration
# Set AI_PROVIDER=openrouter and AI_MODEL=nvidia/nemotron-3-super-120b-a12b:free to use this.
OPENROUTER_API_KEY=

# AI Service Rate Limiting
AI_MAX_REQUESTS_PER_MINUTE=10
AI_REQUEST_TIMEOUT_SECONDS=60

# Application Settings
LOG_LEVEL=INFO
WORKERS=4

# Redis Configuration (optional, for caching)
REDIS_URL=redis://localhost:6379/0
USE_CACHE=False

# Email Configuration (optional, for notifications)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Feature Flags
ENABLE_RESUME_OPTIMIZATION=True
ENABLE_COVER_LETTER_GENERATION=True
ENABLE_JOB_MATCHING=True
ENABLE_INTERVIEW_PREPARATION=False

# Pagination Defaults
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Mock Data
USE_MOCK_JOBS=True
SEED_DATABASE_ON_STARTUP=True
